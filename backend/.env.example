# Backend runtime
HOST=0.0.0.0
PORT=8000
RELOAD=true
DEBUG=false
LOG_LEVEL=info

# API behavior
FRONTEND_ORIGIN=http://localhost:8501
CSRF_TTL_SECONDS=600
BLOG_RATE_LIMIT_MAX=5
BLOG_RATE_LIMIT_WINDOW_SECONDS=3600

# Model runtime
MODEL_ROOT=../models
MODEL_IDLE_SECONDS=180
MODEL_MANAGER_VERBOSE=false
SENTIMENT_MODEL_DIR=
CATEGORY_MODEL_DIR=
REFERENCE_SENTIMENT_MODEL_ID=cardiffnlp/twitter-roberta-base-sentiment-latest

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
